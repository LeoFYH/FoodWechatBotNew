LLM_API_KEY=your_deepseek_api_key
LLM_BASE_URL=https://api.deepseek.com
MODEL_NAME=deepseek-chat

MAX_HISTORY_MESSAGES=20
SYSTEM_PROMPT=你是一个运行在微信里的 AI 助手，回答要简洁、有帮助。
# Optional: load a longer system prompt from a UTF-8 text file.
# PROMPT_FILE=prompts/needs_discovery_v4.md
# Optional: include the current user-turn count in the LLM context.
PROMPT_TURN_CONTEXT=true

# Optional: override the local memory file path.
# MEMORY_FILE=memory.json
# Optional: persist each user's current mode and unfinished order draft.
SESSION_STATE_FILE=session_state.json
# Optional: persist confirmed order rows.
ORDER_FILE=orders.json
# Optional: public base URL used in WeChat export links, for example https://your-app.onrender.com
# PUBLIC_BASE_URL=

# Optional: export interview feedback as an XLSX workbook.
EXPORT_DIR=exports
# EXPORT_TOKEN=change_me
INTERVIEW_ARCHIVE_FILE=interviews.json
INTERVIEW_IDLE_ARCHIVE_SECONDS=300
INTERVIEW_ARCHIVE_POLL_SECONDS=60

# Enterprise WeChat smart bot URL callback settings.
# Fill these with the Token and EncodingAESKey generated on the WeCom bot page.
WECOM_CALLBACK_TOKEN=
WECOM_ENCODING_AES_KEY=
WECOM_CORP_ID=
WECOM_BOT_NAME=食品厂机器人

# Enterprise WeChat customer service callback settings.
# This is a separate channel and does not replace the smart bot settings above.
WECOM_KF_CORP_ID=
WECOM_KF_SECRET=
WECOM_KF_CALLBACK_TOKEN=
WECOM_KF_ENCODING_AES_KEY=
WECOM_KF_CURSOR_FILE=kf_cursors.json
WECOM_KF_SYNC_LIMIT=100
